
# --- Cloudinary (photo uploads in /admin) ---
# From your Cloudinary dashboard -> Settings -> API Keys ("View Keys" in the email).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- MailerSend (the enquiry/contact form) ---
# MAILERSEND_API_KEY: MailerSend dashboard -> Integrations/API tokens.
# ENQUIRY_TO:   where enquiries land (e.g. the shop's Gmail).
# ENQUIRY_FROM: a VERIFIED MailerSend sender address (from a verified domain / the trial domain).
# ENQUIRY_FROM_NAME: display name on the email (optional).
MAILERSEND_API_KEY=
ENQUIRY_TO=
ENQUIRY_FROM=
ENQUIRY_FROM_NAME=Louise's Florist website
